# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/estoubem

# ── Server ────────────────────────────────────────────────
PORT=3000
JWT_SECRET=your-secret-key-change-in-prod

# ── Admin Dashboard ───────────────────────────────────────
ADMIN_PASSWORD=your-admin-password

# ── AppsFlyer ─────────────────────────────────────────────
APPSFLYER_DEV_KEY=your-appsflyer-dev-key
APPSFLYER_APP_ID=com.estoubem.app
APPSFLYER_IOS_APP_ID=1234567890

# ── RevenueCat ────────────────────────────────────────────
REVENUECAT_APPLE_API_KEY=appl_your_key_here
REVENUECAT_GOOGLE_API_KEY=goog_your_key_here

# ── WhatsApp (Grasshopper/group bot) ─────────────────────
WHATSAPP_API_URL=https://your-bot-url
WHATSAPP_API_KEY=your-api-key
