{
  "expo": {
    "name": "Estou Bem",
    "slug": "estou-bem",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.twerner.estoubem",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Estou Bem usa dados de sa\u00fade para monitorar o bem-estar do idoso e alertar familiares.",
        "NSHealthUpdateUsageDescription": "Estou Bem registra check-ins de sa\u00fade para acompanhamento familiar.",
        "NSMotionUsageDescription": "Estou Bem detecta movimento para verificar automaticamente se o idoso est\u00e1 ativo.",
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "package": "com.twerner.estoubem",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F5F0EB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@bacons/apple-targets"
      ]
    ],
    "owner": "timwernerdxb"
  }
}